# Copy this file to .env and adjust as needed.
# All values below are the defaults used by docker/compose.yml.

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC_TRADES=crypto.trades.v1
KAFKA_CLIENT_ID=crypto-producer
KAFKA_ACKS=all
KAFKA_CONSUMER_GROUP=crypto-consumer
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_TOPIC_DLQ=crypto.trades.dlq.v1
DLQ_MAX_BYTES=200000

# ── Binance ───────────────────────────────────────────────────────────────────
BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@trade

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Storage ───────────────────────────────────────────────────────────────────
PARQUET_ROOT=s3://crypto-trades
PARQUET_TOPIC_SUBDIR=trades
BATCH_SIZE=5000
FLUSH_SECONDS=10

# ── MinIO (S3-compatible object store, started via docker/compose.yml) ────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=crypto-trades

# ── Teradata (data warehouse + dbt compute engine) ────────────────────────────
TERADATA_HOST=localhost
TERADATA_USER=dbc
TERADATA_PASSWORD=dbc
# Default Teradata database used by dbt when no custom schema is set
TERADATA_SCHEMA=crypto_db
# MinIO endpoint as reachable FROM the Teradata server (may differ from
# MINIO_ENDPOINT when Teradata is on a separate machine — e.g. use the host
# LAN IP instead of localhost).  Falls back to MINIO_ENDPOINT if unset.
#TERADATA_NOS_ENDPOINT=http://192.168.1.x:9000
